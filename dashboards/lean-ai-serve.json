{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(lean_ai_serve_requests_total[5m]))",
          "legendFormat": "total",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "expr": "sum(rate(lean_ai_serve_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(lean_ai_serve_requests_total{status=~\"5..\"}[5m])) / sum(rate(lean_ai_serve_requests_total[5m])) * 100",
          "legendFormat": "error %",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}
      }
    },
    {
      "title": "Request Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(lean_ai_serve_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(lean_ai_serve_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(lean_ai_serve_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Inference Tokens/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(lean_ai_serve_inference_tokens_total[5m])) by (model, type)",
          "legendFormat": "{{model}} ({{type}})",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "title": "Inference Latency by Model",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(lean_ai_serve_inference_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p95",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Models Loaded",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 8},
      "targets": [
        {
          "expr": "lean_ai_serve_models_loaded",
          "legendFormat": "loaded",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}
      }
    },
    {
      "title": "Active Training Jobs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 8},
      "targets": [
        {
          "expr": "lean_ai_serve_training_jobs_active",
          "legendFormat": "active",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "title": "GPU Memory per Device",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "lean_ai_serve_gpu_memory_used_bytes / 1024 / 1024 / 1024",
          "legendFormat": "GPU {{gpu}} (GiB)",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "decgbytes"}
      }
    },
    {
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "lean_ai_serve_gpu_utilization_pct",
          "legendFormat": "GPU {{gpu}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "max": 100}
      }
    },
    {
      "title": "Active Alerts",
      "type": "table",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "format": "table",
          "instant": true,
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "title": "Auth Failures",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "sum(rate(lean_ai_serve_auth_failures_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["lean-ai-serve", "inference", "gpu"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(lean_ai_serve_inference_tokens_total, model)",
        "name": "model",
        "query": "label_values(lean_ai_serve_inference_tokens_total, model)",
        "refresh": 2,
        "type": "query",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "lean-ai-serve",
  "uid": "lean-ai-serve-overview",
  "version": 1
}
